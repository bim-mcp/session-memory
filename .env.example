# Storage: 'sqlite' or 'postgresql'
MEMORY_STORAGE=sqlite

# Transport: 'stdio' or 'streamable-http'
MCP_TRANSPORT=stdio

# Request body size limit (streamable-http mode)
MCP_MAX_REQUEST_SIZE=10mb

# API key for HTTP auth (empty = no auth)
MCP_API_KEY=

# Default user identity (used when X-User-Id header not provided)
DEFAULT_USER_ID=default

# Port (only used when MCP_TRANSPORT=streamable-http)
MCP_PORT=3000

# SQLite (only used when MEMORY_STORAGE=sqlite)
SQLITE_PATH=./data/memory.db

# PostgreSQL (only used when MEMORY_STORAGE=postgresql)
DATABASE_URL=postgresql://user:password@localhost:5432/session_memory
PG_POOL_MIN=0
PG_POOL_MAX=10
PG_IDLE_TIMEOUT=10000

# --- Embedding ---
# Provider: 'ollama' (default, free) or 'openai' (optional)
EMBEDDING_PROVIDER=ollama

# Vector dimensions (must match provider+model)
# bge-m3 = 1024, nomic-embed-text = 768, text-embedding-3-small = 1536
EMBEDDING_DIMENSIONS=1024

# Embedding request timeout in ms
EMBEDDING_TIMEOUT=30000

# Semantic dedup threshold (0 = off, 0.95 = 95% similarity triggers dedup)
DEDUP_THRESHOLD=0.95

# Search ranking boost values
SEARCH_SELF_BOOST=0.2
SEARCH_TAG_BOOST=0.1

# Ollama (default)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=bge-m3

# OpenAI (only when EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
